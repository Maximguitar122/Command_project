@model Luftreise_Command_project_.Models.SearchModels

@{
    ViewData["Title"] = "Головна - Luftreise";

    var from = Model?.From ?? "";
    var to = Model?.To ?? "";
    var flightDate = Model?.FlightDate != default
        ? Model.FlightDate.ToString("yyyy-MM-dd")
        : "";
}

<section class="hero">
    <div class="hero-content">
        <h1 class="title">Luftreise</h1>
        <p class="subtitle">Відкрийте світ разом з Luftreise</p>

        <div class="search-form-container">
            <form asp-action="Search" asp-controller="Home" method="post" class="search-form">

                <div class="form-row form-row-top">
                    <div class="input-group">
                        <label for="from">Звідки</label>
                        <input id="from" type="text" name="From" placeholder="Київ (KBP)" value="@from" />
                    </div>

                    <div class="swap-wrapper">
                        <button type="button" class="swap-btn" onclick="swapFields()" aria-label="Поміняти місцями напрямки">
                            ↔
                        </button>
                    </div>

                    <div class="input-group">
                        <label for="to">Куди</label>
                        <input id="to" type="text" name="To" placeholder="Париж (CDG)" value="@to" />
                    </div>
                </div>

                <div class="form-row">
                    <div class="input-group">
                        <label for="flightDate">Дата вильоту</label>
                        <input id="flightDate" type="date" name="FlightDate" value="@flightDate" />
                    </div>

                    <div class="input-group">
                        <label for="returnDate">Дата повернення</label>
                        <input id="returnDate" type="date" name="ReturnDate" />
                    </div>
                </div>

                <button type="submit" class="search-btn">
                    Знайти рейси →
                </button>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function swapFields() {
            const fromInput = document.getElementById('from');
            const toInput = document.getElementById('to');

            const temp = fromInput.value;
            fromInput.value = toInput.value;
            toInput.value = temp;
        }
    </script>
}